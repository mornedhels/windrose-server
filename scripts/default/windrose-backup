#!/bin/bash
. "$(dirname "$0")/common"
. "$(dirname "$0")/defaults"

pidfile=$windrose_backup_pidfile
backup_dir=""
worldIslandId=""

main() {
  info "Running windrose-backup"
  prepareBackup
  info "windrose-backup complete"
}

prepareBackup() {
  if [ -f "$pidfile" ]; then
    info "Found existing PID file - checking process"
    checkLock $pidfile
  fi


  if [ ! -d "$saves_dir" ]; then
    warn "Saves directory not found - aborting backup"
    return
  fi

  if [ ! -f "$server_config" ]; then
    warn "Server config file not found - aborting backup"
    return
  fi

  if ! ls $world_config_glob 1> /dev/null 2>&1; then
    warn "WorldDescription.json not found - aborting backup"
    return
  fi


  if ! getWorldIslandId; then
    warn "Failed to get worldIslandId - aborting backup"
    return
  fi
  getBackupDir

  trap shutdown SIGINT SIGTERM

  backupAndCleanup &
  windrose_backup_pid=$!
  echo $windrose_backup_pid >"$pidfile"
  wait $windrose_backup_pid
}

backupAndCleanup() {
  if ! backup; then
    warn "Backup failed - skipping cleanup"
    clearLock "$pidfile"
    return 1
  fi
  cleanup
  backupPostHook
  clearLock "$pidfile"
}

backup() {
  local backup_file_name
  local server_config_name
  debug "run backup"

  backupPreHook

  server_config_name="$(basename "$server_config")"

  backup_file_name="$(date +%Y-%m-%d_%H-%M-%S)-$worldIslandId.zip"
  info "Backing up save file to $backup_dir/$backup_file_name"

  # Temporarily copy ServerDescription.json beside RocksDB for flat zip structure
  cp "$server_config" "$saves_dir_base/$saves_dir_profile/$server_config_name"

  debug "cd \"$saves_dir_base\" && zip -r \"$backup_dir/$backup_file_name\" \"$saves_dir_profile/$saves_dir_rocksdb\" \"$saves_dir_profile/$server_config_name\""
  if ! (cd "$saves_dir_base" && zip -q -r "$backup_dir/$backup_file_name" "$saves_dir_profile/$saves_dir_rocksdb" "$saves_dir_profile/$server_config_name"); then
    rm -f "$saves_dir_base/$saves_dir_profile/$server_config_name"
    warn "Backup zip failed - aborting"
    return 1
  fi

  rm -f "$saves_dir_base/$saves_dir_profile/$server_config_name"
}

cleanup() {
  debug "run cleanup"

  # skip if BACKUP_MAX_COUNT is not set or is 0
  if [ -z "$BACKUP_MAX_COUNT" ] || [ "$BACKUP_MAX_COUNT" -eq 0 ]; then
    warn "Skipping cleanup - BACKUP_MAX_COUNT is not set or is 0 (infinite)"
    return
  fi

  info "Removing old backups with number of backups set to $BACKUP_MAX_COUNT"
  find "$backup_dir" -type f -name "*.zip" -printf '%T@ %p\n' | sort -n | cut -d' ' -f 2- | head -n -$BACKUP_MAX_COUNT | xargs rm -fv
}

getBackupDir() {
  if [[ "$BACKUP_DIR" == /* ]]; then
    backup_dir="$BACKUP_DIR"
  else
    backup_dir="$install_path/$BACKUP_DIR"
  fi
}

backupPreHook() {
  if [ -n "$BACKUP_PRE_HOOK" ]; then
    info "Running backup pre hook: $BACKUP_PRE_HOOK"
    eval "$BACKUP_PRE_HOOK"
  fi
}

backupPostHook() {
  if [ -n "$BACKUP_POST_HOOK" ]; then
    info "Running backup post hook: $BACKUP_POST_HOOK"
    eval "$BACKUP_POST_HOOK"
  fi
}

shutdown() {
  debug "Received signal to shut down windrose-backup"
  clearLock "$pidfile"
}

getWorldIslandId() {
  local world_description_file
  world_description_file=$(ls $world_config_glob 2>/dev/null | head -n 1)

  if [ -z "$world_description_file" ]; then
    warn "WorldDescription.json not found"
    return 1
  fi

  worldIslandId=$(basename "$(dirname "$world_description_file")")
  debug "Extracted worldIslandId: $worldIslandId from $world_description_file"
}

main
