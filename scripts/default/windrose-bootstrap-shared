#!/bin/bash
. "$(dirname "$0")/common"
. "$(dirname "$0")/defaults"

prepareWindroseAppFolders() {
  mkdir -p "$install_path"
}

initCrontab() {
  crontab=$(mktemp)

  if [ -n "$UPDATE_CRON" ]; then
    debug "creating cron for update checks (schedule: $UPDATE_CRON)"
    echo "$UPDATE_CRON supervisorctl start windrose-updater >/dev/null 2>&1" >>"$crontab"
  fi

  if [ -n "$BACKUP_CRON" ]; then
    debug "creating cron for backups (schedule: $BACKUP_CRON)"
    echo "$BACKUP_CRON supervisorctl start windrose-backup >/dev/null 2>&1" >>"$crontab"
  fi

  if [ -n "$RESTART_CRON" ]; then
    debug "creating cron for server restarts (schedule: $RESTART_CRON)"
    echo "$RESTART_CRON supervisorctl start windrose-restart >/dev/null 2>&1" >>"$crontab"
  fi


  crontab "$crontab"
  rm -f "$crontab"
}

bootstrapHook() {
  if [ -n "$BOOTSTRAP_HOOK" ]; then
    info "Running bootstrap hook: $BOOTSTRAP_HOOK"
    eval "$BOOTSTRAP_HOOK"
  fi
}

snakeToPascal() {
  local input="$1"
  local result=""
  local word

  IFS='_' read -ra parts <<< "$input"
  for word in "${parts[@]}"; do
    result+="$(echo "${word:0:1}" | tr '[:lower:]' '[:upper:]')$(echo "${word:1}" | tr '[:upper:]' '[:lower:]')"
  done

  echo "$result"
}

isExcludedKey() {
  local key="$1"
  case "$key" in
    PersistentServerId|WorldIslandId|IsPasswordProtected)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

resolveJsonKey() {
  local env_name="$1"
  local stripped="${env_name#SERVER_}"

  # Special alias: SERVER_NAME -> ServerName
  if [ "$stripped" = "NAME" ]; then
    echo "ServerName"
    return
  fi

  snakeToPascal "$stripped"
}

waitForServerConfig() {
  local timeout=300
  local elapsed=0

  info "ServerDescription.json not found - starting updater to generate it"
  supervisorctl start windrose-updater

  while [ ! -f "$server_config" ]; do
    if [ "$elapsed" -ge "$timeout" ]; then
      warn "Timeout waiting for ServerDescription.json after ${timeout}s"
      return 1
    fi
    debug "Waiting for ServerDescription.json to be created..."
    sleep 2
    elapsed=$((elapsed + 2))
  done

  info "ServerDescription.json appeared - waiting 5s for write completion"
  sleep 5

  info "Stopping windrose-server for config update"
  supervisorctl stop windrose-server

  return 0
}

applyServerEnvVars() {
  local config_tmp
  config_tmp=$(mktemp)
  cp "$server_config" "$config_tmp"

  while IFS='=' read -r env_name env_value; do
    # Skip vars that are not set in the environment (inherited vs explicitly set)
    if [ -z "${!env_name+x}" ]; then
      continue
    fi

    local json_key
    json_key=$(resolveJsonKey "$env_name")

    if isExcludedKey "$json_key"; then
      debug "Skipping excluded key: $json_key (from $env_name)"
      continue
    fi

    local value="${!env_name}"

    # For non-Password fields, skip if value is empty
    if [ "$json_key" != "Password" ] && [ -z "$value" ]; then
      debug "Skipping empty value for $json_key"
      continue
    fi

    debug "Updating ServerDescription_Persistent.$json_key from $env_name"

    # Determine value type and apply with jq
    if [[ "$value" =~ ^[0-9]+$ ]]; then
      jq --tab --arg key "$json_key" --argjson val "$value" \
        '.ServerDescription_Persistent[$key] = $val' "$config_tmp" > "${config_tmp}.new" && mv "${config_tmp}.new" "$config_tmp"
    elif [ "$value" = "true" ] || [ "$value" = "false" ]; then
      jq --tab --arg key "$json_key" --argjson val "$value" \
        '.ServerDescription_Persistent[$key] = $val' "$config_tmp" > "${config_tmp}.new" && mv "${config_tmp}.new" "$config_tmp"
    else
      jq --tab --arg key "$json_key" --arg val "$value" \
        '.ServerDescription_Persistent[$key] = $val' "$config_tmp" > "${config_tmp}.new" && mv "${config_tmp}.new" "$config_tmp"
    fi
  done < <(env | grep '^SERVER_' | sort)

  # Special case: SERVER_PASSWORD controls IsPasswordProtected
  if [ -n "${SERVER_PASSWORD+x}" ]; then
    if [ -n "$SERVER_PASSWORD" ]; then
      debug "SERVER_PASSWORD is set - enabling password protection"
      jq --tab '.ServerDescription_Persistent.IsPasswordProtected = true' "$config_tmp" > "${config_tmp}.new" && mv "${config_tmp}.new" "$config_tmp"
    else
      debug "SERVER_PASSWORD is empty - disabling password protection"
      jq --tab '.ServerDescription_Persistent.IsPasswordProtected = false' "$config_tmp" > "${config_tmp}.new" && mv "${config_tmp}.new" "$config_tmp"
    fi
  fi

  mv "$config_tmp" "$server_config"
  info "ServerDescription.json updated successfully"
}

updateWindroseServerConfig() {
  if [ ! -f "$server_config" ]; then
    if ! waitForServerConfig; then
      warn "Could not obtain ServerDescription.json - skipping config update"
      return 1
    fi
  fi

  # Check if any SERVER_ env vars are set
  if env | grep -q '^SERVER_'; then
    info "Applying SERVER_* environment variables to ServerDescription.json"
    applyServerEnvVars
  else
    info "No SERVER_* environment variables set - skipping config update"
  fi
}

resolveWorldSettingsTag() {
  local env_suffix="$1"
  local result=""
  local part

  # Split on __ to get dot-separated segments
  IFS='§' read -ra segments <<< "${env_suffix//__/§}"
  for segment in "${segments[@]}"; do
    if [ -n "$result" ]; then
      result+="."
    fi
    result+="$(snakeToPascal "$segment")"
  done

  echo "WDS.Parameter.$result"
}

isExcludedWorldKey() {
  local key="$1"
  case "$key" in
    islandId|IslandId|CreationTime)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

applyWorldEnvVars() {
  local world_config="$1"
  local config_tmp
  config_tmp=$(mktemp)
  cp "$world_config" "$config_tmp"

  while IFS='=' read -r env_name env_value; do
    # Skip vars that are not set in the environment
    if [ -z "${!env_name+x}" ]; then
      continue
    fi

    local value="${!env_name}"

    # Skip empty values
    if [ -z "$value" ]; then
      debug "Skipping empty value for $env_name"
      continue
    fi

    local stripped="${env_name#WORLD_}"

    # Check if this is a WORLD_SETTINGS_ variable
    if [[ "$stripped" == SETTINGS_* ]]; then
      local settings_suffix="${stripped#SETTINGS_}"
      local tag
      tag=$(resolveWorldSettingsTag "$settings_suffix")
      local tag_key="{\"TagName\": \"$tag\"}"

      debug "Updating WorldDescription.WorldSettings from $env_name (tag: $tag)"

      if [ "$value" = "true" ] || [ "$value" = "false" ]; then
        # BoolParameters
        jq --tab --arg key "$tag_key" --argjson val "$value" \
          '.WorldDescription.WorldSettings.BoolParameters[$key] = $val' "$config_tmp" > "${config_tmp}.new" && mv "${config_tmp}.new" "$config_tmp"
      elif [[ "$value" =~ ^[0-9]+\.?[0-9]*$ ]] || [[ "$value" =~ ^\.[0-9]+$ ]]; then
        # FloatParameters
        jq --tab --arg key "$tag_key" --argjson val "$value" \
          '.WorldDescription.WorldSettings.FloatParameters[$key] = $val' "$config_tmp" > "${config_tmp}.new" && mv "${config_tmp}.new" "$config_tmp"
      else
        # TagParameters - value is appended to tag name
        jq --tab --arg key "$tag_key" --arg tag_val "$tag.$value" \
          '.WorldDescription.WorldSettings.TagParameters[$key] = {"TagName": $tag_val}' "$config_tmp" > "${config_tmp}.new" && mv "${config_tmp}.new" "$config_tmp"
      fi
    else
      # Top-level WorldDescription field
      local json_key
      json_key=$(snakeToPascal "$stripped")

      # Special alias: WORLD_NAME -> WorldName, WORLD_PRESET_TYPE -> WorldPresetType
      if [ "$stripped" = "NAME" ]; then
        json_key="WorldName"
      elif [ "$stripped" = "PRESET_TYPE" ]; then
        json_key="WorldPresetType"
      fi

      if isExcludedWorldKey "$json_key"; then
        debug "Skipping excluded key: $json_key (from $env_name)"
        continue
      fi

      debug "Updating WorldDescription.$json_key from $env_name"

      if [[ "$value" =~ ^[0-9]+$ ]]; then
        jq --tab --arg key "$json_key" --argjson val "$value" \
          '.WorldDescription[$key] = $val' "$config_tmp" > "${config_tmp}.new" && mv "${config_tmp}.new" "$config_tmp"
      elif [ "$value" = "true" ] || [ "$value" = "false" ]; then
        jq --tab --arg key "$json_key" --argjson val "$value" \
          '.WorldDescription[$key] = $val' "$config_tmp" > "${config_tmp}.new" && mv "${config_tmp}.new" "$config_tmp"
      else
        jq --tab --arg key "$json_key" --arg val "$value" \
          '.WorldDescription[$key] = $val' "$config_tmp" > "${config_tmp}.new" && mv "${config_tmp}.new" "$config_tmp"
      fi
    fi
  done < <(env | grep '^WORLD_' | sort)

  mv "$config_tmp" "$world_config"
  info "WorldDescription.json updated successfully"
}

updateWindroseWorldConfig() {
  # Find world config via glob
  local world_config
  world_config=$(compgen -G "$world_config_glob" | head -n 1)

  if [ -z "$world_config" ]; then
    warn "WorldDescription.json not found - skipping world config update"
    return 1
  fi

  # Check if any WORLD_ env vars are set
  if env | grep -q '^WORLD_'; then
    info "Applying WORLD_* environment variables to WorldDescription.json"
    applyWorldEnvVars "$world_config"
  else
    info "No WORLD_* environment variables set - skipping world config update"
  fi
}
